# =============================================================================
# AI Developer Copilot Platform — Local Development Environment
# =============================================================================
# Copy this file to .env and fill in real values before running the stack.
# Never commit a .env file with real secrets to version control.
#
# SERVICE TOPOLOGY (local docker compose):
#   postgres:5432   → primary PostgreSQL (Alembic migrations only)
#   pgbouncer:5432  → PgBouncer in transaction mode (application DB path)
#   redis:6379      → Redis (broker db=1, result db=2, app cache db=0)
#   qdrant:6333     → Qdrant vector store
#   minio:9000      → MinIO object storage (S3-compatible)
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# DATABASE_URL     → application path: routes through PgBouncer (port 5432)
# DATABASE_DIRECT_URL → migration path: connects directly to PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://copilot:copilot@pgbouncer:5432/copilot
DATABASE_DIRECT_URL=postgresql+asyncpg://copilot:copilot@postgres:5432/copilot

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Celery
# Using separate Redis databases for broker and result backend to prevent
# result records from polluting the task queue stream.
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Qdrant
# QDRANT_API_KEY is optional; leave empty for unauthenticated local instances.
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Object Storage (MinIO in local dev; AWS S3 or GCS in production)
# The copilot-dev bucket is created automatically by the minio-setup service.
# -----------------------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_BUCKET=copilot-dev
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1

# -----------------------------------------------------------------------------
# LLM Provider — OpenAI-compatible /v1/chat/completions
# Switch provider by changing LLM_BASE_URL:
#   OpenAI:      https://api.openai.com
#   Groq:        https://api.groq.com/openai
#   Ollama:      http://host.docker.internal:11434
# -----------------------------------------------------------------------------
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-replace-with-your-key
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Embedding Provider — OpenAI-compatible /v1/embeddings
# Can share the same endpoint and key as LLM_BASE_URL or use a separate service.
# -----------------------------------------------------------------------------
EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_API_KEY=sk-replace-with-your-key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=512

# -----------------------------------------------------------------------------
# JWT
# JWT_SECRET_KEY must be a long, random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
